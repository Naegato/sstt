PORT=3001
ALLOWED_ORIGINS=http://localhost:3000
WEB_ORIGIN=http://localhost:3000

# Doit correspondre au docker-compose.yml racine
DATABASE_URL=postgres://card_game:card_game@localhost:5432/card_game

# À changer en production (secret de signature JWT)
JWT_SECRET=dev-secret-change-me

# OAuth — laisser vide en dev désactive simplement ces boutons (401/501 propre, pas de crash)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3001/api/auth/discord/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
